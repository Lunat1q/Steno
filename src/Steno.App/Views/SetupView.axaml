<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Steno.App.ViewModels"
             x:Class="Steno.App.Views.SetupView"
             x:DataType="vm:MainViewModel">

    <!--
      Two dropdowns and a button. Everything else is either explained inline or hidden under
      "More options", because the only decision that actually matters is which two streams to
      listen to — and even that is pre-filled with the system defaults.
    -->
    <ScrollViewer>
        <Border Classes="card" MaxWidth="620" Margin="0,8,0,0">
            <StackPanel Spacing="20">

                <StackPanel Spacing="4">
                    <TextBlock Classes="title" Text="Set up the call" />
                    <TextBlock Classes="hint"
                               Text="Steno listens to two things at once — your voice and the call's audio — so it always knows who said what." />
                </StackPanel>

                <!-- Step 1 -->
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                    <Border Grid.Column="0" Classes="badge" Margin="0,2,12,0">
                        <TextBlock Text="1" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="step" Text="Your microphone" />
                        <ComboBox ItemsSource="{Binding Setup.Microphones}"
                                  SelectedItem="{Binding Setup.Microphone}"
                                  Margin="0,8,0,0" />
                        <TextBlock Classes="hint">
                            <Run Text="Whatever this hears is labelled" />
                            <Run Text="You" FontWeight="SemiBold" Foreground="{DynamicResource You}" />
                            <Run Text="in the transcript." />
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Step 2 -->
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" Classes="badge" Margin="0,2,12,0">
                        <TextBlock Text="2" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="step" Text="Where you hear the call" />
                        <ComboBox ItemsSource="{Binding Setup.Speakers}"
                                  SelectedItem="{Binding Setup.Speaker}"
                                  Margin="0,8,0,0" />
                        <TextBlock Classes="hint">
                            <Run Text="Steno records the sound coming out of this device, so the other person is labelled" />
                            <Run Text="Them" FontWeight="SemiBold" Foreground="{DynamicResource Them}" />
                            <Run Text="— works with Teams, Zoom, a browser, anything. Nothing to install in the call app." />
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- Step 3 -->
                <Grid ColumnDefinitions="Auto,*">
                    <Border Grid.Column="0" Classes="badge" Margin="0,2,12,0">
                        <TextBlock Text="3" />
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="step" Text="Language and quality" />
                        <Grid ColumnDefinitions="*,12,*" Margin="0,8,0,0">
                            <ComboBox Grid.Column="0" ItemsSource="{Binding Setup.Languages}"
                                      SelectedItem="{Binding Setup.Language}" />
                            <ComboBox Grid.Column="2" ItemsSource="{Binding Setup.Qualities}"
                                      SelectedItem="{Binding Setup.Quality}" />
                        </Grid>
                        <TextBlock Classes="hint" Text="{Binding Setup.Quality.Detail}" />
                        <TextBlock Classes="hint" Text="{Binding Setup.DownloadNotice}"
                                   Foreground="{DynamicResource Warn}"
                                   IsVisible="{Binding Setup.NeedsDownload}" />
                    </StackPanel>
                </Grid>

                <!-- The one piece of advice that changes the result. Not buried in a tooltip. -->
                <Border Classes="banner">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🎧" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock Classes="hint" Foreground="{DynamicResource Text}" MaxWidth="470"
                                   Text="Wear a headset. On loudspeakers your microphone also picks up the other person, and their words can end up under your name." />
                    </StackPanel>
                </Border>

                <!-- Recording is a first-class choice, not an advanced one: you either want the
                     audio kept or you don't, and you must decide before the call, not after. -->
                <StackPanel>
                    <CheckBox Content="Save the call audio" IsChecked="{Binding Setup.RecordAudio}" />
                    <TextBlock Classes="hint" Margin="28,0,0,0"
                               Text="One stereo file in Documents\Steno\recordings — you on the left, them on the right — so it can be transcribed again later with everyone still labelled. Nothing is recorded while paused." />
                </StackPanel>

                <Expander Header="More options" Background="Transparent">
                    <StackPanel Spacing="14" Margin="0,10,0,0">
                        <StackPanel>
                            <CheckBox Content="Also translate into English"
                                      IsChecked="{Binding Setup.TranslateToEnglish}" />
                            <TextBlock Classes="hint" Margin="28,0,0,0"
                                       Text="Adds an English line under each one. English is the only language the engine can translate into." />
                        </StackPanel>
                        <StackPanel>
                            <CheckBox Content="Show words as they are spoken"
                                      IsChecked="{Binding Setup.ShowLiveDraft}" />
                            <TextBlock Classes="hint" Margin="28,0,0,0"
                                       Text="Rough text appears mid-sentence and is corrected when the sentence ends. Uses noticeably more CPU." />
                        </StackPanel>
                        <StackPanel>
                            <CheckBox Content="Ignore the other person leaking into my microphone"
                                      IsChecked="{Binding Setup.SuppressEcho}" />
                            <TextBlock Classes="hint" Margin="28,0,0,0"
                                       Text="For when you are on loudspeakers. Harmless with a headset." />
                        </StackPanel>
                    </StackPanel>
                </Expander>

                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Classes="primary" Content="Start listening" Command="{Binding StartCommand}" />
                    <Button Classes="quiet" Content="Rescan devices" Command="{Binding Setup.RefreshDevicesCommand}"
                            VerticalAlignment="Center" />
                </StackPanel>

                <Border Height="1" Background="{DynamicResource Border}" />

                <!-- The other way in: a call that already happened. -->
                <StackPanel Spacing="6">
                    <TextBlock Classes="step" Text="Already have a recording?" />
                    <TextBlock Classes="hint"
                               Text="Transcribe a saved call. A stereo file recorded by Steno keeps both speakers apart; any other audio is transcribed as one." />
                    <Button Classes="quiet" Content="Transcribe a recording…" Click="OnTranscribeFileClick"
                            HorizontalAlignment="Left" Margin="0,4,0,0" />
                </StackPanel>

            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
