<?xml version="1.0" encoding="utf-8"?>
<!--
  Self-contained Steno for Windows x64. Produces Steno.App.exe plus whisper.cpp's native
  runtimes/ folder — that folder is not optional, see below. The installer packages both.

      dotnet publish src/Steno.App -p:PublishProfile=SingleFile
      installer/build.ps1                       # -> Steno-Setup.msi

  No .NET install is needed on the target machine.
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishDir>bin\publish\</PublishDir>

    <SelfContained>true</SelfContained>

    <!-- Every *managed* assembly goes into the exe: no wall of DLLs next to it. -->
    <PublishSingleFile>true</PublishSingleFile>

    <!--
      OFF, deliberately. Turning it on swallows whisper.cpp's DLLs into the exe, where Whisper.net
      cannot find them: it locates them by *directory* (runtimes/vulkan/win-x64/…), while
      single-file extraction is flat — and there the CPU and Vulkan builds collide anyway, both
      being named whisper.dll. The result is an exe that starts fine and then throws "Native
      Library not found in default paths" the moment the user presses Start. Verified, not
      guessed. So the natives stay on disk next to the exe, and the installer ships them. ADR 0017.
    -->
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>

    <!--
      Trimming is OFF and must stay off: Avalonia resolves controls, styles and compiled-binding
      types reflectively, and the trimmer cannot see those references.
    -->
    <PublishTrimmed>false</PublishTrimmed>

    <!--
      ReadyToRun off: measured, it adds 48 MB to save a few hundred ms of JIT on a startup that
      is already dominated by loading a multi-GB model. Bad trade for a download.
    -->
    <PublishReadyToRun>false</PublishReadyToRun>

    <DebugType>embedded</DebugType>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <AllowedReferenceRelatedFileExtensions>none</AllowedReferenceRelatedFileExtensions>
    <DebugSymbols>false</DebugSymbols>
  </PropertyGroup>

  <Target Name="StripPublishLeftovers" AfterTargets="Publish">
    <ItemGroup>
      <!-- Skia/HarfBuzz ship native .pdb files as package content — 100 MB of them, copied next
           to the exe whatever the symbol properties say. -->
      <Leftovers Include="$(PublishDir)**\*.pdb" />
      <!-- The whisper.cpp runtime packages copy every platform's binaries, including Linux and
           macOS ones this build can never load. -->
      <Leftovers Include="$(PublishDir)**\*.so" />
      <Leftovers Include="$(PublishDir)**\*.dylib" />
      <!-- Other architectures' whisper builds. Only win-x64 is shipped. -->
      <Leftovers Include="$(PublishDir)runtimes\win-x86\**\*" />
      <Leftovers Include="$(PublishDir)runtimes\win-arm64\**\*" />
    </ItemGroup>
    <Delete Files="@(Leftovers)" />
  </Target>
</Project>
